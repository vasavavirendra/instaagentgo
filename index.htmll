<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>InstaAgent</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --pink: #e91e8c;
    --pink2: #ff5ec4;
    --dark: #0d0d14;
    --card: #13131f;
    --border: rgba(233,30,140,0.18);
    --text: #f0eaff;
    --muted: #9490aa;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--dark); color:var(--text); font-family:'DM Sans',sans-serif; min-height:100vh; }

  /* NAV */
  nav {
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 24px;
    background:rgba(13,13,20,0.95);
    border-bottom:1px solid var(--border);
    position:sticky; top:0; z-index:100;
    backdrop-filter:blur(12px);
  }
  .logo { font-family:'Syne',sans-serif; font-weight:800; font-size:1.4rem; color:#fff; }
  .logo span { color:var(--pink); }
  .nav-links { display:flex; gap:20px; }
  .nav-links a { color:var(--muted); text-decoration:none; font-size:.9rem; transition:.2s; }
  .nav-links a:hover { color:#fff; }
  .btn-nav {
    background:linear-gradient(135deg,var(--pink),var(--pink2));
    color:#fff; border:none; padding:9px 20px;
    border-radius:50px; font-family:'Syne',sans-serif; font-weight:600;
    cursor:pointer; font-size:.9rem;
  }

  /* HERO */
  .hero {
    text-align:center; padding:70px 24px 50px;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(233,30,140,.15), transparent);
  }
  .badge {
    display:inline-block; background:rgba(233,30,140,.12);
    border:1px solid var(--border); color:var(--pink2);
    padding:5px 16px; border-radius:50px; font-size:.8rem;
    font-family:'Syne',sans-serif; font-weight:600; margin-bottom:18px;
    animation: fadeUp .6s ease both;
  }
  .hero h1 {
    font-family:'Syne',sans-serif; font-size:clamp(2rem,6vw,3.2rem);
    font-weight:800; line-height:1.15; margin-bottom:16px;
    animation: fadeUp .7s ease both;
  }
  .hero h1 span {
    background:linear-gradient(90deg,var(--pink),var(--pink2));
    -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  }
  .hero p { color:var(--muted); max-width:480px; margin:0 auto 32px; font-size:1rem; animation:fadeUp .8s ease both; }
  .hero-btns { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; animation:fadeUp .9s ease both; }
  .btn-primary {
    background:linear-gradient(135deg,var(--pink),var(--pink2));
    color:#fff; border:none; padding:13px 32px;
    border-radius:50px; font-family:'Syne',sans-serif; font-weight:700;
    cursor:pointer; font-size:1rem; box-shadow:0 0 30px rgba(233,30,140,.3);
    transition:.2s;
  }
  .btn-primary:hover { transform:translateY(-2px); box-shadow:0 0 40px rgba(233,30,140,.5); }
  .btn-outline {
    background:transparent; color:#fff;
    border:1px solid rgba(255,255,255,.2);
    padding:13px 32px; border-radius:50px;
    font-family:'Syne',sans-serif; font-weight:600;
    cursor:pointer; font-size:1rem; transition:.2s;
  }
  .btn-outline:hover { border-color:var(--pink); color:var(--pink2); }

  /* STATS */
  .stats {
    display:flex; justify-content:center; gap:40px; flex-wrap:wrap;
    padding:30px 24px;
    border-top:1px solid var(--border); border-bottom:1px solid var(--border);
    background:var(--card);
  }
  .stat { text-align:center; }
  .stat-num { font-family:'Syne',sans-serif; font-size:1.8rem; font-weight:800; color:var(--pink2); }
  .stat-label { font-size:.8rem; color:var(--muted); margin-top:2px; }

  /* PLATFORM TABS */
  .section { padding:50px 24px; max-width:700px; margin:0 auto; }
  .section-title { font-family:'Syne',sans-serif; font-size:1.5rem; font-weight:800; margin-bottom:8px; }
  .section-sub { color:var(--muted); font-size:.9rem; margin-bottom:28px; }

  .tabs { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:24px; }
  .tab {
    padding:8px 18px; border-radius:50px; font-size:.85rem; font-weight:500;
    border:1px solid var(--border); background:transparent; color:var(--muted);
    cursor:pointer; transition:.2s; font-family:'DM Sans',sans-serif;
  }
  .tab.active { background:linear-gradient(135deg,var(--pink),var(--pink2)); color:#fff; border-color:transparent; }

  /* PLANS */
  .plans { display:flex; flex-direction:column; gap:12px; }
  .plan-card {
    display:flex; align-items:center; justify-content:space-between;
    background:var(--card); border:1px solid var(--border);
    border-radius:14px; padding:16px 20px;
    transition:.2s; cursor:pointer;
  }
  .plan-card:hover { border-color:var(--pink); transform:translateX(4px); }
  .plan-card.featured { border-color:var(--pink); background:rgba(233,30,140,.07); }
  .plan-badge { background:var(--pink); color:#fff; font-size:.65rem; font-weight:700; padding:2px 8px; border-radius:50px; margin-left:8px; font-family:'Syne',sans-serif; }
  .plan-name { font-family:'Syne',sans-serif; font-weight:700; font-size:1rem; }
  .plan-desc { color:var(--muted); font-size:.8rem; margin-top:2px; }
  .plan-price {
    background:linear-gradient(135deg,var(--pink),var(--pink2));
    color:#fff; padding:8px 18px; border-radius:50px;
    font-family:'Syne',sans-serif; font-weight:700; font-size:.95rem;
    white-space:nowrap; border:none; cursor:pointer;
  }

  /* ORDER FORM */
  .order-section {
    background:var(--card); border:1px solid var(--border);
    border-radius:20px; padding:28px 24px; max-width:700px; margin:0 auto 50px;
  }
  .order-section h2 { font-family:'Syne',sans-serif; font-size:1.2rem; font-weight:800; margin-bottom:6px; }
  .order-section p { color:var(--muted); font-size:.85rem; margin-bottom:20px; }
  .form-group { margin-bottom:16px; }
  .form-group label { display:block; font-size:.8rem; font-weight:500; color:var(--muted); margin-bottom:6px; }
  .form-group input, .form-group select {
    width:100%; background:#0d0d14; border:1px solid var(--border);
    color:#fff; padding:12px 16px; border-radius:12px;
    font-family:'DM Sans',sans-serif; font-size:.95rem;
    outline:none; transition:.2s;
  }
  .form-group input:focus, .form-group select:focus { border-color:var(--pink); }
  .form-group select option { background:#1a1a2e; }
  .btn-order {
    width:100%; background:linear-gradient(135deg,var(--pink),var(--pink2));
    color:#fff; border:none; padding:14px;
    border-radius:12px; font-family:'Syne',sans-serif; font-weight:700;
    cursor:pointer; font-size:1rem; margin-top:8px;
    box-shadow:0 0 24px rgba(233,30,140,.3); transition:.2s;
  }
  .btn-order:hover { transform:translateY(-2px); box-shadow:0 0 36px rgba(233,30,140,.5); }

  /* PAYMENT MODAL */
  .modal-overlay {
    display:none; position:fixed; inset:0;
    background:rgba(0,0,0,.7); z-index:999;
    backdrop-filter:blur(6px);
    align-items:center; justify-content:center;
  }
  .modal-overlay.open { display:flex; }
  .modal {
    background:var(--card); border:1px solid var(--border);
    border-radius:20px; padding:32px 28px; max-width:380px; width:90%;
    animation:fadeUp .3s ease;
  }
  .modal h3 { font-family:'Syne',sans-serif; font-size:1.2rem; font-weight:800; margin-bottom:6px; }
  .modal p { color:var(--muted); font-size:.85rem; margin-bottom:20px; }
  .upi-box {
    background:#0d0d14; border:1px solid var(--border);
    border-radius:12px; padding:16px; text-align:center; margin-bottom:16px;
  }
  .upi-label { font-size:.75rem; color:var(--muted); margin-bottom:4px; }
  .upi-id { font-family:'Syne',sans-serif; font-weight:700; font-size:1.05rem; color:var(--pink2); }
  .upi-amount { font-size:.85rem; color:var(--muted); margin-top:6px; }
  .upi-amount span { color:#fff; font-weight:600; }
  .steps { margin-bottom:20px; }
  .step { display:flex; gap:10px; align-items:flex-start; margin-bottom:10px; font-size:.85rem; }
  .step-num {
    min-width:22px; height:22px; border-radius:50%;
    background:linear-gradient(135deg,var(--pink),var(--pink2));
    display:flex; align-items:center; justify-content:center;
    font-size:.7rem; font-weight:700; font-family:'Syne',sans-serif;
  }
  .btn-upi {
    display:block; width:100%;
    background:linear-gradient(135deg,#00c853,#00e676);
    color:#fff; border:none; padding:13px;
    border-radius:12px; font-family:'Syne',sans-serif; font-weight:700;
    cursor:pointer; font-size:.95rem; text-decoration:none; text-align:center;
    margin-bottom:10px;
  }
  .btn-close {
    display:block; width:100%; background:transparent;
    border:1px solid var(--border); color:var(--muted);
    padding:11px; border-radius:12px; font-family:'Syne',sans-serif;
    font-weight:600; cursor:pointer; font-size:.9rem;
  }

  /* FEATURES */
  .features {
    display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
    gap:14px; max-width:700px; margin:0 auto 50px; padding:0 24px;
  }
  .feature-card {
    background:var(--card); border:1px solid var(--border);
    border-radius:14px; padding:20px 16px; text-align:center;
  }
  .feature-icon { font-size:1.8rem; margin-bottom:10px; }
  .feature-title { font-family:'Syne',sans-serif; font-weight:700; font-size:.9rem; margin-bottom:4px; }
  .feature-text { color:var(--muted); font-size:.78rem; }

  /* FOOTER */
  footer {
    text-align:center; padding:24px; border-top:1px solid var(--border);
    color:var(--muted); font-size:.8rem;
  }
  footer span { color:var(--pink2); }

  @keyframes fadeUp {
    from { opacity:0; transform:translateY(20px); }
    to { opacity:1; transform:translateY(0); }
  }

  /* HIDDEN PLAN DATA */
  .plan-cards-wrap { display:none; }
  .plan-cards-wrap.active { display:flex; flex-direction:column; gap:12px; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">Insta<span>Agent</span></div>
  <div class="nav-links">
    <a href="#plans">Plans</a>
    <a href="#order">Order</a>
    <a href="https://whatsapp.com/channel/0029Vb6SUGPF6sms8up5lt1u" target="_blank">📢 Channel</a>
    <a href="https://wa.me/919999999999" target="_blank">Support</a>
  </div>
  <button class="btn-nav" onclick="document.getElementById('order').scrollIntoView({behavior:'smooth'})">Buy Now</button>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="badge">🔥 Ramadan Special Offer</div>
  <h1>Grow Your Social Media<br><span>Fast & Affordable</span></h1>
  <p>Real followers, likes, views & more for Instagram, YouTube, Facebook and beyond.</p>
  <div class="hero-btns">
    <button class="btn-primary" onclick="document.getElementById('plans').scrollIntoView({behavior:'smooth'})">View Plans</button>
    <button class="btn-outline" onclick="document.getElementById('order').scrollIntoView({behavior:'smooth'})">Place Order</button>
  </div>
</div>

<!-- STATS -->
<div class="stats">
  <div class="stat"><div class="stat-num">50K+</div><div class="stat-label">Happy Customers</div></div>
  <div class="stat"><div class="stat-num">24/7</div><div class="stat-label">Customer Support</div></div>
  <div class="stat"><div class="stat-num">100%</div><div class="stat-label">Secure & Safe</div></div>
  <div class="stat"><div class="stat-num">Fast</div><div class="stat-label">Instant Delivery</div></div>
</div>

<!-- WA CHANNEL BANNER -->
<div style="max-width:700px;margin:24px auto 0;padding:0 24px;">
  <a href="https://whatsapp.com/channel/0029Vb6SUGPF6sms8up5lt1u" target="_blank"
     style="display:flex;align-items:center;gap:14px;background:#0d1f18;border:1px solid #25d366;border-radius:14px;padding:16px 20px;text-decoration:none;"
  >
    <div style="font-size:2rem;">💬</div>
    <div>
      <div style="font-family:'Syne',sans-serif;font-weight:700;color:#25d366;font-size:.95rem;">Join Our WhatsApp Channel</div>
      <div style="color:#9490aa;font-size:.8rem;margin-top:2px;">Get latest offers, updates & deals instantly</div>
    </div>
    <div style="margin-left:auto;background:#25d366;color:#fff;padding:7px 16px;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;font-size:.8rem;white-space:nowrap;">Join Now →</div>
  </a>
</div>

<div class="section" id="plans">
  <div class="section-title">Choose Your Plan</div>
  <div class="section-sub">Select a platform and pick the package that suits you.</div>

  <div class="tabs">
    <button class="tab active" onclick="showTab('instagram',this)">📸 Instagram</button>
    <button class="tab" onclick="showTab('youtube',this)">▶️ YouTube</button>
    <button class="tab" onclick="showTab('facebook',this)">📘 Facebook</button>
  </div>

  <!-- INSTAGRAM PLANS -->
  <div class="plan-cards-wrap active" id="instagram">
    <div class="plan-card featured" onclick="selectPlan('50 Followers','8')">
      <div><div class="plan-name">50 Followers <span class="plan-badge">STARTER</span></div><div class="plan-desc">Mixed High Quality</div></div>
      <button class="plan-price">₹8</button>
    </div>
    <div class="plan-card" onclick="selectPlan('100 Followers','13')">
      <div><div class="plan-name">100 Followers</div><div class="plan-desc">Mixed High Quality</div></div>
      <button class="plan-price">₹13</button>
    </div>
    <div class="plan-card" onclick="selectPlan('1000 Followers','49')">
      <div><div class="plan-name">1,000 Followers</div><div class="plan-desc">Indian Real Non-drop</div></div>
      <button class="plan-price">₹49</button>
    </div>
    <div class="plan-card" onclick="selectPlan('2000 Followers','79')">
      <div><div class="plan-name">2,000 Followers</div><div class="plan-desc">Indian Real Non-drop</div></div>
      <button class="plan-price">₹79</button>
    </div>
    <div class="plan-card" onclick="selectPlan('5000 Followers','149')">
      <div><div class="plan-name">5,000 Followers</div><div class="plan-desc">Indian Real Non-drop</div></div>
      <button class="plan-price">₹149</button>
    </div>
    <div class="plan-card featured" onclick="selectPlan('1 Million Followers (Ramadan Special)','499')">
      <div><div class="plan-name">1M Followers 🎉 <span class="plan-badge">HOT DEAL</span></div><div class="plan-desc">Indian Real Non-drop</div></div>
      <button class="plan-price">₹499</button>
    </div>
    <div class="plan-card" onclick="selectPlan('1000 Likes','19')">
      <div><div class="plan-name">1,000 Post Likes</div><div class="plan-desc">Real High Quality</div></div>
      <button class="plan-price">₹19</button>
    </div>
    <div class="plan-card" onclick="selectPlan('50000 Reel Views','49')">
      <div><div class="plan-name">50,000 Reel Views</div><div class="plan-desc">Fast Delivery</div></div>
      <button class="plan-price">₹49</button>
    </div>
  </div>

  <!-- YOUTUBE PLANS -->
  <div class="plan-cards-wrap" id="youtube">
    <div class="plan-card" onclick="selectPlan('1000 YouTube Subscribers','49')">
      <div><div class="plan-name">1,000 Subscribers</div><div class="plan-desc">Real Non-drop</div></div>
      <button class="plan-price">₹49</button>
    </div>
    <div class="plan-card" onclick="selectPlan('4000 Watch Hours','99')">
      <div><div class="plan-name">4,000 Watch Hours</div><div class="plan-desc">Monetization Ready</div></div>
      <button class="plan-price">₹99</button>
    </div>
    <div class="plan-card featured" onclick="selectPlan('6700 YouTube Subscribers','149')">
      <div><div class="plan-name">6,700 Subscribers <span class="plan-badge">POPULAR</span></div><div class="plan-desc">Real Non-drop</div></div>
      <button class="plan-price">₹149</button>
    </div>
    <div class="plan-card" onclick="selectPlan('50000 YouTube Likes','79')">
      <div><div class="plan-name">50,000 Likes</div><div class="plan-desc">Real High Quality</div></div>
      <button class="plan-price">₹79</button>
    </div>
  </div>

  <!-- FACEBOOK PLANS -->
  <div class="plan-cards-wrap" id="facebook">
    <div class="plan-card" onclick="selectPlan('1000 Facebook Followers','29')">
      <div><div class="plan-name">1,000 Followers</div><div class="plan-desc">Real Non-drop</div></div>
      <button class="plan-price">₹29</button>
    </div>
    <div class="plan-card" onclick="selectPlan('5000 Facebook Followers','99')">
      <div><div class="plan-name">5,000 Followers</div><div class="plan-desc">Real Non-drop</div></div>
      <button class="plan-price">₹99</button>
    </div>
    <div class="plan-card featured" onclick="selectPlan('10000 Facebook Likes','149')">
      <div><div class="plan-name">10,000 Page Likes <span class="plan-badge">BEST VALUE</span></div><div class="plan-desc">Indian Real</div></div>
      <button class="plan-price">₹149</button>
    </div>
