</div>

<!-- ORDER FORM -->
<div class="order-section" id="order">
  <h2>📦 Place Your Order</h2>
  <p>Fill in your details and complete payment via UPI instantly.</p>
  <div class="form-group">
    <label>Your Name</label>
    <input type="text" id="cust-name" placeholder="Enter your name"/>
  </div>
  <div class="form-group">
    <label>WhatsApp Number</label>
    <input type="tel" id="cust-phone" placeholder="+91 XXXXXXXXXX"/>
  </div>
  <div class="form-group">
    <label>Instagram / YouTube / Facebook Profile Link</label>
    <input type="url" id="cust-link" placeholder="https://instagram.com/yourprofile"/>
  </div>
  <div class="form-group">
    <label>Select Service</label>
    <select id="cust-service">
      <option value="" disabled selected>-- Choose a plan --</option>
      <optgroup label="Instagram">
        <option value="50 Followers|8">50 Followers – ₹8</option>
        <option value="100 Followers|13">100 Followers – ₹13</option>
        <option value="1000 Followers|49">1,000 Followers – ₹49</option>
        <option value="2000 Followers|79">2,000 Followers – ₹79</option>
        <option value="5000 Followers|149">5,000 Followers – ₹149</option>
        <option value="1 Million Followers|499">1M Followers (Ramadan Special) – ₹499</option>
        <option value="1000 Post Likes|19">1,000 Likes – ₹19</option>
        <option value="50000 Reel Views|49">50,000 Reel Views – ₹49</option>
      </optgroup>
      <optgroup label="YouTube">
        <option value="1000 YouTube Subscribers|49">1,000 Subscribers – ₹49</option>
        <option value="4000 Watch Hours|99">4,000 Watch Hours – ₹99</option>
        <option value="6700 YouTube Subscribers|149">6,700 Subscribers – ₹149</option>
        <option value="50000 YouTube Likes|79">50,000 Likes – ₹79</option>
      </optgroup>
      <optgroup label="Facebook">
        <option value="1000 Facebook Followers|29">1,000 Followers – ₹29</option>
        <option value="5000 Facebook Followers|99">5,000 Followers – ₹99</option>
        <option value="10000 Facebook Likes|149">10,000 Page Likes – ₹149</option>
      </optgroup>
    </select>
  </div>
  <button class="btn-order" onclick="openPayment()">💳 Proceed to Payment</button>
</div>

<!-- FEATURES -->
<div class="features">
  <div class="feature-card"><div class="feature-icon">⚡</div><div class="feature-title">Fast Delivery</div><div class="feature-text">Orders start within minutes</div></div>
  <div class="feature-card"><div class="feature-icon">🔒</div><div class="feature-title">100% Safe</div><div class="feature-text">No password needed</div></div>
  <div class="feature-card"><div class="feature-icon">🏆</div><div class="feature-title">Real Quality</div><div class="feature-text">Non-drop followers</div></div>
  <div class="feature-card"><div class="feature-icon">💬</div><div class="feature-title">24/7 Support</div><div class="feature-text">Always here to help</div></div>
</div>

<!-- PAYMENT MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <h3>💳 Complete Payment</h3>
    <p>Send payment via UPI and share screenshot on WhatsApp to confirm your order.</p>
    <div class="upi-box">
      <div class="upi-label">UPI ID</div>
      <div class="upi-id">instagramagentof@oksbi</div>
      <div class="upi-amount">Amount: <span id="modal-amount">₹0</span></div>
    </div>
    <div class="steps">
      <div class="step"><div class="step-num">1</div><div>Copy the UPI ID and open any UPI app (GPay, PhonePe, Paytm)</div></div>
      <div class="step"><div class="step-num">2</div><div>Send exactly <strong id="step-amount">₹0</strong> to the UPI ID above</div></div>
      <div class="step"><div class="step-num">3</div><div>Screenshot the payment confirmation</div></div>
      <div class="step"><div class="step-num">4</div><div>Send screenshot + your profile link on WhatsApp to receive your order</div></div>
    </div>
    <a href="upi://pay?pa=instagramagentof@oksbi&pn=InstaAgent&am=0&cu=INR" id="upi-link" class="btn-upi">📲 Open UPI App to Pay</a>
    <a href="https://wa.me/919999999999?text=Hi%2C%20I%20have%20made%20payment%20for%20my%20order.%20Please%20confirm." target="_blank" class="btn-upi" style="background:linear-gradient(135deg,#25d366,#128c7e); margin-bottom:10px;">💬 Send Screenshot on WhatsApp</a>
    <button class="btn-close" onclick="closeModal()">Close</button>
  </div>
</div>

<footer>
  © 2025 <span>InstaAgent</span> · All rights reserved · UPI: instagramagentof@oksbi<br/>
  <a href="https://whatsapp.com/channel/0029Vb6SUGPF6sms8up5lt1u" target="_blank" style="color:#25d366;text-decoration:none;font-size:.85rem;">💬 Join WhatsApp Channel</a>
</footer>

<script>
  function showTab(platform, btn) {
    document.querySelectorAll('.plan-cards-wrap').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
    document.getElementById(platform).classList.add('active');
    btn.classList.add('active');
  }

  function selectPlan(name, price) {
    const sel = document.getElementById('cust-service');
    for (let i = 0; i < sel.options.length; i++) {
      if (sel.options[i].value === name + '|' + price) {
        sel.selectedIndex = i;
        break;
      }
    }
    document.getElementById('order').scrollIntoView({ behavior: 'smooth' });
  }

  function openPayment() {
    const name = document.getElementById('cust-name').value.trim();
    const phone = document.getElementById('cust-phone').value.trim();
    const link = document.getElementById('cust-link').value.trim();
    const service = document.getElementById('cust-service').value;

    if (!name || !phone || !link || !service) {
      alert('Please fill in all fields and select a service.');
      return;
    }

    const parts = service.split('|');
    const planName = parts[0];
    const price = parts[1];

    document.getElementById('modal-amount').textContent = '₹' + price;
    document.getElementById('step-amount').textContent = '₹' + price;

    const upiLink = `upi://pay?pa=instagramagentof@oksbi&pn=InstaAgent&am=${price}&cu=INR&tn=${encodeURIComponent(planName)}`;
    document.getElementById('upi-link').href = upiLink;

    const waMsg = encodeURIComponent(`Hi, I want to order:\nPlan: ${planName}\nAmount: ₹${price}\nProfile: ${link}\nName: ${name}\nPhone: ${phone}`);
    document.querySelector('.btn-upi:last-of-type').href = `https://wa.me/919999999999?text=${waMsg}`;

    document.getElementById('modal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('open');
  }

  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
</script>
</body>
</html>
